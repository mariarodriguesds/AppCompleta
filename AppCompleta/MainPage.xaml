<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCompleta.MainPage"
             Title="Login"
             BackgroundColor="#121212">

    <ScrollView>
        <Grid RowDefinitions="*, Auto, *" Padding="30">

            <!-- Logo/Título -->
            <StackLayout Grid.Row="1" Spacing="30">

                <Frame BackgroundColor="#1E1E1E"
                       HasShadow="True"
                       CornerRadius="20"
                       Padding="0">

                    <StackLayout Padding="30" Spacing="20">
                        <Label Text="Bem-vindo!"
                               FontSize="28"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="#FFFFFF"/>

                        <Label Text="Faça login para continuar"
                               FontSize="16"
                               HorizontalOptions="Center"
                               TextColor="#B0B0B0"
                               Margin="0,0,0,20" />

                        <!-- Campo Login -->
                        <Entry x:Name="EntryLogin"
                               Placeholder="Login"
                               FontSize="16"
                               BackgroundColor="#2C2C2C"
                               PlaceholderColor="#808080"
                               TextColor="#FFFFFF"
                               HeightRequest="50"
                               />

                        <!-- Campo Senha -->
                        <Entry x:Name="EntrySenha"
                               Placeholder="Senha"
                               IsPassword="True"
                               FontSize="16"
                               BackgroundColor="#2C2C2C"
                               PlaceholderColor="#808080"
                               TextColor="#FFFFFF"
                               HeightRequest="50"

                               />

                        <!-- Botão Login -->
                        <Button x:Name="BntLogin"
                                Text="ENTRAR"
                                BackgroundColor="#3B82F6"
                                TextColor="White"
                                FontSize="16"
                                FontAttributes="Bold"
                                HeightRequest="50"
                                CornerRadius="25"
                                Clicked="OnLoginClicked"/>

                        <!-- Link Cadastro -->
                        <Button x:Name="BtnCadastro"
                                Text="Não tem conta? Cadastre-se"
                                BackgroundColor="Transparent"
                                TextColor="#3B82F6"
                                FontSize="14"
                                Clicked="OnCadastroClicked"/>
                    </StackLayout>
                </Frame>
            </StackLayout>

           
        </Grid>
        
    </ScrollView>

</ContentPage>
